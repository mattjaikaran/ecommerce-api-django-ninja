# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=api.settings.dev
DEBUG=1
SECRET_KEY=dev-secret-key-change-in-production

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=ecommerce_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db        # "db" inside Docker, "localhost" for local dev
DB_PORT=5432

# ── Redis & Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Production only — set a strong password and reference it in REDIS_URL:
# REDIS_PASSWORD=changeme
# REDIS_URL=redis://:changeme@redis:6379/0

# ── Hosts & CORS ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,django
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME=5
JWT_REFRESH_TOKEN_LIFETIME=1

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (production) ────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── Superuser (auto-created on first `make up` if set) ────────────────────────
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=changeme

# ── Flower monitoring (production) ────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=changeme

# ── Sentry (production) ───────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── TLS (production) ─────────────────────────────────────────────────────────
USE_TLS=0

# ── AWS S3 (optional) ─────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=

# ── Docker project name ───────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=ecommerce-api
